# =============================================================================
# Elos API — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env — apenas .env.example vai ao repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados
# Dev: Postgres no Docker (`docker compose up`). Com tudo no Docker, o
# docker-compose.yml sobrescreve DATABASE_URL e DIRECT_URL para o serviço `postgres`,
# então rode migrations/seed dentro do container:
#   docker compose exec api pnpm db:migrate
#   docker compose exec api pnpm db:seed
# Prod: Supabase — DATABASE_URL via pooler (PgBouncer, 6543) e DIRECT_URL conexão
# direta (5432, exigida pelas migrations). Use os valores comentados abaixo.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://elos:elos@localhost:5432/elos"
DIRECT_URL="postgresql://elos:elos@localhost:5432/elos"

# Prod (Supabase) — substituir as duas linhas acima por:
# DATABASE_URL="postgresql://user:password@pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://user:password@db.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Better-Auth
# BETTER_AUTH_SECRET deve ter no mínimo 32 caracteres.
# Gere um valor seguro com: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET="your-secret-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# CORS — URL base do frontend (sem trailing slash)
# -----------------------------------------------------------------------------
FRONTEND_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
PORT=3333
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase Storage (upload de NFs e documentos — Fase 6, apenas prod)
# Não é necessário em dev com Postgres no Docker. Deixe em branco localmente.
# SUPABASE_SERVICE_ROLE_KEY nunca vai ao frontend.
# -----------------------------------------------------------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
